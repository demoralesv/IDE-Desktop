<Window x:Class="Decorator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Decorator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid x:Name="Syntaxbutton">
        <RichTextBox x:Name="Texto" HorizontalAlignment="Center" Height="239" VerticalAlignment="Center" Width="480">
        </RichTextBox>
        <Button x:Name="NewScriptbutton" Content="CargarScript" HorizontalAlignment="Left" Height="23" Margin="160,47,0,0" VerticalAlignment="Top" Width="77" Click="LoadScript"/>
        <Button x:Name="Syntax" Content="Syntax" HorizontalAlignment="Left" Height="23" Margin="268,47,0,0" VerticalAlignment="Top" Width="77" Click="FormText"/>
        <Button x:Name="FirmarButton" Content="Firmar" HorizontalAlignment="Left" Height="23" Margin="400,48,0,0" VerticalAlignment="Top" Width="77" Click="Sign"/>
        <Button x:Name="Verificar" Content="Verificarfirma" HorizontalAlignment="Left" Margin="566,47,0,0" VerticalAlignment="Top" Height="23" Click="CompareFirm"/>

    </Grid>
</Window>
