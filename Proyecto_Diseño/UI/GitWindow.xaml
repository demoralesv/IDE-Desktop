<Window x:Class="Proyecto_Diseño.UI.GitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto_Diseño.UI"
        mc:Ignorable="d"
        Title="GitWindow" Height="443" Width="800">
    <Grid Margin="0,0,0,137">
        <RichTextBox x:Name="LogGit" Margin="10,37,10,68" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
            <RichTextBox.Resources>
                <Style TargetType="{x:Type Paragraph}">
                    <Setter Property="LineHeight" Value="10"></Setter>
                    <Setter Property="LineStackingStrategy" Value="BlockLineHeight"></Setter>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>
        <RichTextBox x:Name="GitTerminal" HorizontalAlignment="Center" Height="31" Margin="0,236,0,0" VerticalAlignment="Top" Width="763" PreviewKeyDown="GitCMD"/>
    </Grid>
</Window>
