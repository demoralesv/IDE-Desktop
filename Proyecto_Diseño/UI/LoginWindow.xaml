<Window x:Class="Proyecto_Diseño.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto_Diseño"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="433*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="259*"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="Correo" HorizontalAlignment="Left" Height="22" Margin="212,98,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="328" Grid.Column="1" Grid.Row="1"/>
        <TextBox x:Name="Password" HorizontalAlignment="Left" Height="22" Margin="212,142,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="328" Grid.Column="1" Grid.Row="1"/>
        <Label x:Name="LabelCorreo" Content="Correo" HorizontalAlignment="Left" Margin="162,98,0,0" VerticalAlignment="Top" Height="22" FontSize="11" Grid.Column="1" Grid.Row="1"/>
        <Label x:Name="LabelPass" Content="Contraseña" HorizontalAlignment="Left" Margin="140,142,0,0" VerticalAlignment="Top" Height="22" FontSize="11" Grid.Column="1" Grid.Row="1"/>
        <Button x:Name="CrearCuentaB" Content="Crear Cuenta" HorizontalAlignment="Left" Margin="240,247,0,0" VerticalAlignment="Top" Grid.Column="1" Grid.Row="1" Click="CrearCuentaB_Click"/>
        <Button x:Name="Iniciar_Sesión" Content="Iniciar sesión" HorizontalAlignment="Left" Margin="404,247,0,0" VerticalAlignment="Top" Grid.Column="1" Grid.Row="1" Click="Iniciar_Sesión_Click"/>
    </Grid>
</Window>
