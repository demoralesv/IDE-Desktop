<Window x:Class="Proyecto_Diseño.UI.CreateAccount"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto_Diseño.UI"
        mc:Ignorable="d"
        Title="CreateAccount" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="NameBox" TextWrapping="Wrap" Margin="275,82,0,0" HorizontalAlignment="Left" Width="302" Height="21" VerticalAlignment="Top"/>
        <Label x:Name="NameLabel" Content="Nombre" HorizontalAlignment="Left" Height="35" Margin="190,81,0,0" VerticalAlignment="Top" Width="56"/>
        <TextBox x:Name="ApellidoBox" Margin="275,122,0,0" TextWrapping="Wrap" HorizontalAlignment="Left" Width="302" Height="21" VerticalAlignment="Top"/>
        <Label x:Name="ApellidoLabel" Content="Apellido" HorizontalAlignment="Left" Height="35" Margin="190,120,0,0" VerticalAlignment="Top" Width="56"/>
        <Label x:Name="CorreoLabel" Content="Correo" Height="35" Margin="190,162,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="56"/>
        <TextBox x:Name="Correobox" TextWrapping="Wrap" Width="302" Height="21.04" Margin="275,164,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBox x:Name="PassBox" Margin="275,206,0,0" TextWrapping="Wrap" HorizontalAlignment="Left" Width="302" Height="22" VerticalAlignment="Top"/>
        <Label x:Name="PassLabel" Content="Contraseña" HorizontalAlignment="Left" Margin="180,204,0,0" VerticalAlignment="Top" Width="76" Height="36"/>
        <Button x:Name="RegistrarButton" Content="Registrarse" HorizontalAlignment="Left" Height="25" Margin="491,281,0,0" VerticalAlignment="Top" Width="86" Click="CreateUserButton"/>

    </Grid>
</Window>
