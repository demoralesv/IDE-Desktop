<Window x:Class="Proyecto_Diseño.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto_Diseño"
        mc:Ignorable="d"
        Title="MainWindow" Height="655" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="400*"/>
            <RowDefinition Height="149*"/>
            <RowDefinition Height="90*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="106"/>
            <ColumnDefinition Width="417*"/>
            <ColumnDefinition Width="277*"/>
        </Grid.ColumnDefinitions>
        <RichTextBox x:Name="IDE" PreviewKeyDown="IDEKey" BorderBrush="Black" Grid.ColumnSpan="3" Grid.RowSpan="2" AcceptsTab="True" Margin="15,24,5,126" VerticalScrollBarVisibility="Visible">
            <RichTextBox.Resources>
                <Style TargetType="{x:Type Paragraph}">
                    <Setter Property="LineHeight" Value="10"></Setter>
                    <Setter Property="LineStackingStrategy" Value="BlockLineHeight"></Setter>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>
        <Button x:Name="LoginButton" Content="Iniciar sesión" Margin="15,3,0,0" VerticalAlignment="Top" Height="19" Click="Button_Click_1" HorizontalAlignment="Left" Width="72"/>
        <Button x:Name="OpenDoc" Content="Abrir documento" HorizontalAlignment="Left" Margin="1,3,0,0" Click="Button_Click" Width="94" Height="19" VerticalAlignment="Top" Grid.Column="1"/>
        <Button x:Name="SaveButton" Content="Guardar" Margin="115,3,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.48,-0.223" Height="19" Click="SaveButton_Click" Grid.Column="1" HorizontalAlignment="Left" Width="54"/>
        <RichTextBox x:Name="LogTerminal" Grid.ColumnSpan="3" BorderBrush="Black" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Margin="14,0,6,85" Grid.Row="1" Grid.RowSpan="2" Height="111" VerticalAlignment="Bottom"/>
        <Button Content="Ejecutar " Margin="14,0,20,10" Grid.Row="2" Click="RunScript" Height="23" VerticalAlignment="Bottom"/>
        <RichTextBox x:Name="CommandTerminal" Grid.ColumnSpan="3" Grid.Row="2" PreviewKeyDown="CmdKeys" Margin="14,0,6,43" Height="37" VerticalAlignment="Bottom"/>
        <Button x:Name="GitButton" Grid.Column="2" Content="Git" Margin="198,0,7,10" Grid.Row="2" Click="GitWindow" Height="22" VerticalAlignment="Bottom"/>
        <Button x:Name="New_File" Grid.Column="1" Content="archivo nuevo" HorizontalAlignment="Left" Margin="190,3,0,0" VerticalAlignment="Top" Width="88" Height="19" Click="NewFile"/>
        <Button x:Name="TareasButton" Grid.Column="2" Content="Mis tareas" HorizontalAlignment="Right" Height="19" Margin="0,3,5,0" VerticalAlignment="Top" Width="89" Click="TareaClick"/>
    </Grid>
</Window>
